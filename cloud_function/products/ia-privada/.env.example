# ═══════════════════════════════════════════════════
# RCP IA Privada — Variables de entorno
# Copiar a .env y llenar con datos del cliente
# ═══════════════════════════════════════════════════

# Nombre del cliente (aparece en la interfaz)
CLIENT_NAME=Mi Empresa SRL

# Clave maestra de LiteLLM (generar una aleatoria)
LITELLM_MASTER_KEY=sk-rcp-CAMBIAR-ESTO-12345

# Modelos a descargar (separados por coma)
# Tier Básico: llama3.1:8b
# Tier Avanzado: llama3.1:8b,mistral:7b,codellama:7b
# Tier Enterprise: llama3.1:70b,mistral:7b,codellama:34b,nomic-embed-text
MODELS_TO_PULL=llama3.1:8b
