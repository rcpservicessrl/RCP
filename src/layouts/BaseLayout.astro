---
/**
 * BaseLayout.astro — Shell común para TODAS las páginas.
 * Centraliza: <head> (meta, OG, JSON-LD, fonts, GA4), Header, Footer,
 * widgets flotantes (chatbot, cookies, tour) y carga de scripts.
 *
 * Antes: el header/footer/nav se duplicaban a mano en 13 HTMLs.
 * Ahora: se define una vez aquí.
 *
 * Props:
 *  - title: título de la página (SEO)
 *  - description: meta description
 *  - canonical: path canónico (ej: "/nosotros")
 *  - active: clave de página activa para resaltar nav
 *  - ogImage: imagen Open Graph
 */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWidgets from '../components/FloatingWidgets.astro';
import '../styles/tokens.css';
import '../styles/base.css';

// Hoja de estilos completa del sitio (servida desde /public, inline para no bundlear)
const SITE_CSS = '/styles.css';
const SITE_JS = '/script.js';
const I18N_JS = '/scripts/i18n.js';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  active?: string;
  ogImage?: string;
}

const {
  title = 'RCP Services | Agencia 360° de Transformación Empresarial y Digital',
  description = 'RCP Services: Tu Junta Directiva Externa en la República Dominicana. Finanzas, legalidad y marketing bajo un solo ecosistema 360° para MIPYMEs.',
  canonical = '/',
  active = '',
  ogImage = '/Logo RCP Services.png',
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') || 'https://rcp.services';
const canonicalUrl = `${site}${canonical}`;
const ogImageUrl = `${site}${ogImage}`;
---

<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="RCP Services, agencia 360, MIPYMEs, República Dominicana, transformación digital, consultoría empresarial, formalización, marketing digital, Santo Domingo" />
  <meta name="author" content="RCP Services SRL" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_DO" />
  <meta property="og:locale:alternate" content="en_US" />
  <meta property="og:site_name" content="RCP Services" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Preconnect & Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet" /></noscript>

  <!-- Favicon & PWA -->
  <link rel="icon" type="image/png" sizes="32x32" href="/icono-rcp.png" />
  <link rel="apple-touch-icon" href="/icono-rcp.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#FCB53F" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <!-- JSON-LD Organization + LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["Organization", "LocalBusiness"],
    "name": "RCP Services SRL",
    "alternateName": "RCP Services",
    "description": "Agencia 360° de Transformación Empresarial y Digital para MIPYMEs en República Dominicana. Renovación, Consultoría y Publicidad bajo un ecosistema soberano con IA.",
    "url": site,
    "logo": `${site}/Logo RCP Services.png`,
    "image": `${site}/Logo RCP Services.png`,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Santo Domingo",
      "addressLocality": "Santo Domingo",
      "addressRegion": "Distrito Nacional",
      "postalCode": "10100",
      "addressCountry": "DO"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "18.4861", "longitude": "-69.9312" },
    "telephone": "+18298068092",
    "email": "info@rcp.services",
    "priceRange": "$$",
    "openingHours": "Mo-Fr 09:00-18:00",
    "areaServed": { "@type": "Country", "name": "Dominican Republic" },
    "sameAs": [
      "https://www.instagram.com/rcp.services_/",
      "https://wa.me/18298068092"
    ]
  })} />

  <!-- GA4 Analytics (carga condicional tras consentimiento de cookies) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'functionality_storage': 'granted',
      'security_storage': 'granted'
    });
    gtag('js', new Date());
    gtag('config', 'G-1NX4MWJ0GD', { 'send_page_view': false });
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1NX4MWJ0GD"></script>
</head>

<body>
  <a href="#inicio" class="skip-to-content">Saltar al contenido principal</a>

  <Header active={active} />

  <slot />

  <Footer />
  <FloatingWidgets />

  <!-- Supabase SDK -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <!-- CSS completo del sitio -->
  <link rel="stylesheet" href={SITE_CSS} is:inline />
  <!-- Script global (chatbot, theme, i18n, animaciones, tour, SW) -->
  <script src={SITE_JS} is:inline defer></script>
  <script src={I18N_JS} is:inline></script>
</body>

</html>
