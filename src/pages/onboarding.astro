---
/**
 * onboarding.astro — Perfil empresarial + Diagnóstico 360 (2 pasos)
 * Requiere sesión activa (sessionStorage). Actualiza cliente en Supabase.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Onboarding — RCP Services"
  description="Completa tu perfil para que podamos personalizar tu Dashboard."
  canonical="/onboarding"
  active="onboarding"
  requiresSupabase={true}
>
  <div class="onboarding-container">
    <div class="step-header">
      <h2 id="stepTitle">Bienvenido a RCP Services</h2>
      <p id="stepDesc">Completa tu perfil para que podamos personalizar tu Dashboard.</p>
    </div>

    <!-- STEP 1 -->
    <div id="step1" class="step-content active">
      <div class="form-group">
        <label for="obPhone">Teléfono de Contacto</label>
        <div style="display: flex; gap: 10px;">
          <select id="phonePrefix" class="form-control" style="width: 140px; flex-shrink: 0; padding: 14px 10px; font-size: 0.9rem;">
            <option value="+1" data-country="DO">🇩🇴 +1 (DO)</option>
            <option value="+1" data-country="US">🇺🇸 +1 (US)</option>
            <option value="+34" data-country="ES">🇪🇸 +34 (ES)</option>
            <option value="+52" data-country="MX">🇲🇽 +52 (MX)</option>
            <option value="+57" data-country="CO">🇨🇴 +57 (CO)</option>
            <option value="+58" data-country="VE">🇻🇪 +58 (VE)</option>
            <option value="+507" data-country="PA">🇵🇦 +507 (PA)</option>
            <option value="+506" data-country="CR">🇨🇷 +506 (CR)</option>
          </select>
          <input type="tel" id="obPhone" class="form-control" placeholder="Ej. 829-806-8092" required />
        </div>
      </div>
      <div class="form-group">
        <label for="obAddress">Dirección Principal</label>
        <input type="text" id="obAddress" class="form-control" placeholder="Ciudad, País o Dirección completa" required />
      </div>
      <div class="form-group">
        <label for="obRnc">RNC / Cédula / Identificación Fiscal</label>
        <input type="text" id="obRnc" class="form-control" placeholder="Ej. 1-31-12345-6" required />
      </div>
      <div class="nav-buttons" style="justify-content: flex-end;">
        <button class="btn-cta" id="btnNext1">Siguiente ➔</button>
      </div>
    </div>

    <!-- STEP 2 -->
    <div id="step2" class="step-content">
      <div class="form-group">
        <label>1. ¿En qué etapa se encuentra tu negocio actualmente?</label>
        <div class="pills-container" id="q1_pills" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 10px;">
          <button type="button" class="ob-pill-btn" data-value="🚀 Idea / Proyecto nuevo">🚀 Idea / Proyecto nuevo</button>
          <button type="button" class="ob-pill-btn" data-value="🌱 Operando (< 1 año)">🌱 Operando (&lt; 1 año)</button>
          <button type="button" class="ob-pill-btn" data-value="📈 En crecimiento (1-3 años)">📈 En crecimiento (1-3 años)</button>
          <button type="button" class="ob-pill-btn" data-value="🏢 Consolidado (> 3 años)">🏢 Consolidado (&gt; 3 años)</button>
        </div>
        <input type="text" id="q1_custom" class="form-control" placeholder="Otro comentario o detalle sobre tu etapa..." />
      </div>
      <div class="form-group">
        <label>2. ¿Cuáles son tus mayores desafíos a nivel legal u operativo?</label>
        <div class="pills-container" id="q2_pills" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 10px;">
          <button type="button" class="ob-pill-btn" data-value="⚖️ Legal / Constitución">⚖️ Legal / Constitución</button>
          <button type="button" class="ob-pill-btn" data-value="🛡️ ONAPI / Registro de Marca">🛡️ ONAPI / Registro de Marca</button>
          <button type="button" class="ob-pill-btn" data-value="💸 Impuestos / DGII">💸 Impuestos / DGII</button>
          <button type="button" class="ob-pill-btn" data-value="📣 Marketing y Ventas">📣 Marketing y Ventas</button>
          <button type="button" class="ob-pill-btn" data-value="⚙️ Operaciones / Procesos">⚙️ Operaciones / Procesos</button>
        </div>
        <input type="text" id="q2_custom" class="form-control" placeholder="Otros desafíos que enfrentas..." />
      </div>
      <div class="form-group">
        <label>3. ¿Qué servicios de RCP te interesan más a corto plazo?</label>
        <div class="pills-container" id="q3_pills" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 10px;">
          <button type="button" class="ob-pill-btn" data-value="📝 Constitución de Empresa">📝 Constitución de Empresa</button>
          <button type="button" class="ob-pill-btn" data-value="🛡️ Registro de Marca ONAPI">🛡️ Registro de Marca ONAPI</button>
          <button type="button" class="ob-pill-btn" data-value="🎨 Identidad Corporativa / Branding">🎨 Identidad Corporativa / Branding</button>
          <button type="button" class="ob-pill-btn" data-value="📊 Campañas Digitales (Ads)">📊 Campañas Digitales (Ads)</button>
          <button type="button" class="ob-pill-btn" data-value="💻 CRM / Odoo Automatizado">💻 CRM / Odoo Automatizado</button>
        </div>
        <input type="text" id="q3_custom" class="form-control" placeholder="Otros servicios de interés..." />
      </div>
      <div class="nav-buttons">
        <button class="btn-outline" id="btnPrev2">← Atrás</button>
        <button class="btn-cta" id="btnSubmitOB">Completar Registro ✓</button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .onboarding-container { max-width: 640px; margin: 120px auto 60px; padding: 0 24px; }
  .step-header { text-align: center; margin-bottom: 40px; }
  .step-header h2 { font-size: 1.8rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .step-header p { color: var(--text-muted); font-size: 0.9rem; }
  :global(.step-content) { display: none; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: var(--radius); padding: 36px; }
  :global(.step-content.active) { display: block; }
  :global(.form-group) { margin-bottom: 22px; }
  :global(.form-group label) { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); margin-bottom: 8px; }
  :global(.nav-buttons) { display: flex; justify-content: space-between; gap: 12px; margin-top: 28px; }
  :global(.btn-outline) { background: none; border: 1px solid var(--card-border); color: var(--text-muted); padding: 12px 24px; border-radius: 10px; font-weight: 600; cursor: pointer; transition: var(--transition); }
  :global(.btn-outline:hover) { border-color: var(--text); color: var(--text); }
  :global(.ob-pill-btn) { background: rgba(255,255,255,0.03); border: 1px solid var(--card-border); color: var(--text); padding: 10px 16px; border-radius: 20px; font-size: 0.82rem; cursor: pointer; transition: var(--transition); }
  :global(.ob-pill-btn:hover) { border-color: var(--accent); }
  :global(.ob-pill-btn.selected) { background: rgba(252,181,63,0.15); border-color: var(--accent); color: var(--accent); font-weight: 600; }
</style>

<script>
  (function() {
    const activeEmail = sessionStorage.getItem('active_user_email');
    const activeRole = sessionStorage.getItem('active_user_role');
    if (!activeEmail) { window.location.href = '/portal'; return; }
    if (activeRole && activeRole !== 'client') { window.location.href = '/dashboard'; return; }

    const isLocal = ['localhost', '127.0.0.1', ''].includes(window.location.hostname);
    const supabaseUrl = isLocal ? 'http://127.0.0.1:54321' : 'https://wpfovxgbennpgydbellw.supabase.co';
    const supabaseKey = isLocal ? 'sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH' : 'sb_publishable_wQHzaXkyhbfuOdDkMAWAKQ_VOE14bfO';
    let supabase: any = null;
    try { if ((window as any).supabase) supabase = (window as any).supabase.createClient(supabaseUrl, supabaseKey); }
    catch (e) { console.error(e); }

    const step1 = document.getElementById('step1')!;
    const step2 = document.getElementById('step2')!;
    const stepTitle = document.getElementById('stepTitle')!;
    const stepDesc = document.getElementById('stepDesc')!;
    const phoneInput = document.getElementById('obPhone') as HTMLInputElement;
    const prefixSelect = document.getElementById('phonePrefix') as HTMLSelectElement;

    if (phoneInput && prefixSelect) {
      phoneInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        let val = target.value;
        let digits = val.replace(/\D/g, '');
        const country = prefixSelect.options[prefixSelect.selectedIndex].getAttribute('data-country');
        if (country === 'DO' || country === 'US') {
          if (digits.length > 10) digits = digits.substring(0, 10);
          let formatted = '';
          if (digits.length > 0) formatted += digits.substring(0, Math.min(3, digits.length));
          if (digits.length > 3) formatted += '-' + digits.substring(3, Math.min(6, digits.length));
          if (digits.length > 6) formatted += '-' + digits.substring(6, digits.length);
          target.value = formatted;
        } else {
          target.value = val.replace(/[^0-9\-\s]/g, '');
        }
      });
      const placeholders: Record<string,string> = { DO: '829-000-0000', US: '555-555-5555', ES: '600 000 000', MX: '55 1234 5678', CO: '300 123 4567', VE: '412 123 4567', PA: '6000-0000', CR: '8000-0000' };
      prefixSelect.addEventListener('change', () => {
        phoneInput.value = '';
        const country = prefixSelect.options[prefixSelect.selectedIndex].getAttribute('data-country');
        phoneInput.placeholder = 'Ej. ' + (placeholders[country || ''] || 'Número telefónico');
      });
    }

    const q1Pills = document.querySelectorAll('#q1_pills .ob-pill-btn');
    q1Pills.forEach(pill => { pill.addEventListener('click', () => { q1Pills.forEach(p => p.classList.remove('selected')); pill.classList.add('selected'); }); });
    const q2Pills = document.querySelectorAll('#q2_pills .ob-pill-btn');
    q2Pills.forEach(pill => { pill.addEventListener('click', () => { pill.classList.toggle('selected'); }); });
    const q3Pills = document.querySelectorAll('#q3_pills .ob-pill-btn');
    q3Pills.forEach(pill => { pill.addEventListener('click', () => { pill.classList.toggle('selected'); }); });

    document.getElementById('btnNext1')!.addEventListener('click', () => {
      const phone = (document.getElementById('obPhone') as HTMLInputElement).value.trim();
      const address = (document.getElementById('obAddress') as HTMLInputElement).value.trim();
      const rnc = (document.getElementById('obRnc') as HTMLInputElement).value.trim();
      const country = prefixSelect.options[prefixSelect.selectedIndex].getAttribute('data-country');
      if (!phone || !address || !rnc) { alert('Por favor, completa todos los campos del Perfil Empresarial antes de continuar.'); return; }
      const digits = phone.replace(/\D/g, '');
      if (country === 'DO') {
        if (digits.length !== 10) { alert('Por favor, ingresa un número de teléfono de 10 dígitos (ej. 829-806-8092).'); return; }
        if (!['809', '829', '849'].includes(digits.substring(0, 3))) { alert('El código de área para República Dominicana debe iniciar con 809, 829 o 849.'); return; }
      } else if (country === 'US') {
        if (digits.length !== 10) { alert('Por favor, ingresa un número de teléfono de 10 dígitos.'); return; }
      } else if (country === 'ES') {
        if (digits.length !== 9) { alert('Por favor, ingresa un número de teléfono válido para España (9 dígitos).'); return; }
      } else {
        if (digits.length < 7) { alert('Por favor, ingresa un número de teléfono válido (mínimo 7 dígitos).'); return; }
      }
      step1.classList.remove('active');
      step2.classList.add('active');
      stepTitle.textContent = "Diagnóstico 360";
      stepDesc.textContent = "Responde seleccionando las opciones o detallando tu caso.";
    });

    document.getElementById('btnPrev2')!.addEventListener('click', () => {
      step2.classList.remove('active');
      step1.classList.add('active');
      stepTitle.textContent = "Bienvenido a RCP Services";
      stepDesc.textContent = "Completa tu perfil para que podamos personalizar tu Dashboard.";
    });

    document.getElementById('btnSubmitOB')!.addEventListener('click', async () => {
      const btnSubmit = document.getElementById('btnSubmitOB') as HTMLButtonElement;
      btnSubmit.textContent = 'Guardando...';
      btnSubmit.disabled = true;

      const q1Selected = document.querySelector('#q1_pills .ob-pill-btn.selected') as HTMLElement | null;
      const q1Val = q1Selected ? q1Selected.getAttribute('data-value') : '';
      const q1Custom = (document.getElementById('q1_custom') as HTMLInputElement).value.trim();
      const q1Final = q1Custom ? (q1Val ? `${q1Val} (${q1Custom})` : q1Custom) : q1Val;

      const q2Selected = Array.from(document.querySelectorAll('#q2_pills .ob-pill-btn.selected')).map(p => (p as HTMLElement).getAttribute('data-value'));
      const q2Custom = (document.getElementById('q2_custom') as HTMLInputElement).value.trim();
      const q2Final = q2Selected.length > 0 ? (q2Custom ? `${q2Selected.join(', ')} (${q2Custom})` : q2Selected.join(', ')) : q2Custom;

      const q3Selected = Array.from(document.querySelectorAll('#q3_pills .ob-pill-btn.selected')).map(p => (p as HTMLElement).getAttribute('data-value'));
      const q3Custom = (document.getElementById('q3_custom') as HTMLInputElement).value.trim();
      const q3Final = q3Selected.length > 0 ? (q3Custom ? `${q3Selected.join(', ')} (${q3Custom})` : q3Selected.join(', ')) : q3Custom;

      const payload = {
        phone: prefixSelect.value + ' ' + (document.getElementById('obPhone') as HTMLInputElement).value.trim(),
        address: (document.getElementById('obAddress') as HTMLInputElement).value.trim(),
        legal_id: (document.getElementById('obRnc') as HTMLInputElement).value.trim(),
        status: 'pending_activation',
        diagnostico_360: { q1_etapa: q1Final, q2_desafios: q2Final, q3_intereses: q3Final }
      };

      if (supabase) {
        try {
          const { error } = await supabase.from('clientes').update(payload).eq('email', activeEmail);
          if (error) throw error;
          window.location.href = '/portal';
          return;
        } catch (err: any) {
          console.error("Error updating onboarding data:", err);
          alert("Hubo un error guardando tu diagnóstico: " + (err.message || err) + ". Intenta de nuevo.");
          btnSubmit.textContent = 'Completar Registro ✓';
          btnSubmit.disabled = false;
          return;
        }
      } else {
        const localUsers = JSON.parse(localStorage.getItem('portal_users') || '[]');
        const idx = localUsers.findIndex((u:any) => u.email === activeEmail);
        if (idx !== -1) {
          localUsers[idx].status = 'pending_activation';
          localUsers[idx].phone = payload.phone;
          localUsers[idx].address = payload.address;
          localUsers[idx].legal_id = payload.legal_id;
          localUsers[idx].diagnostico_360 = payload.diagnostico_360;
          localStorage.setItem('portal_users', JSON.stringify(localUsers));
        }
        window.location.href = '/portal';
      }
    });
  })();
</script>
