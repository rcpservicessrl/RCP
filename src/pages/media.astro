---
/**
 * media.astro — Video corporativo, podcast y recursos multimedia
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Media — RCP Services | Video, Podcast y Recursos"
  description="Video corporativo, podcast estratégico y recursos que inspiran la reanimación de tu negocio."
  canonical="/media"
  active="media"
>
  <section class="hero hero-short" id="inicio">
    <div class="hero-bg-grid"></div>
    <div class="container" style="position: relative; width: 100%; padding-top: 120px;">
      <div class="hero-content">
        <div class="hero-badge animate-fade-up">
          <span class="badge-dot"></span> <span data-i18n="media-badge">Contenido Multimedia</span>
        </div>
        <h1 class="hero-title animate-fade-up delay-1" data-i18n="media-title">
          Aprende, crece y <span class="accent">transforma</span>
        </h1>
        <p class="hero-sub animate-fade-up delay-2" data-i18n="media-sub">
          Video corporativo, podcast estratégico y recursos que inspiran la reanimación de tu negocio.
        </p>
      </div>
    </div>
  </section>

  <main>
    <!-- VIDEO 1 -->
    <section class="section problema">
      <div class="container">
        <div class="section-label animate-on-scroll" data-i18n="media-video-label">Video Corporativo</div>
        <h2 class="section-title animate-on-scroll" data-i18n="media-video-title">RCP: <span class="accent">Crecimiento Imparable</span></h2>
        <p class="section-sub animate-on-scroll" data-i18n="media-video-desc">
          Descubre cómo transformamos MIPYMEs dominicanas con nuestro ecosistema integral de renovación, consultoría y publicidad.
        </p>
        <div class="media-player animate-on-scroll">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/3uyrVE2TepY" title="RCP: Crecimiento Imparable"
              frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div class="media-details animate-on-scroll">
          <h3 data-i18n="media-video-notes-title">📋 Sobre este video</h3>
          <ul>
            <li data-i18n="media-video-note1">Presentación del ecosistema R·C·P y cómo impacta a las MIPYMEs</li>
            <li data-i18n="media-video-note2">Casos de uso de la Agencia 360° en República Dominicana</li>
            <li data-i18n="media-video-note3">Nuestra propuesta de valor y diferenciación en el mercado</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- VIDEO 2 -->
    <section class="section trust">
      <div class="container">
        <div class="section-label animate-on-scroll" data-i18n="media-video2-label">Presentación Estratégica</div>
        <h2 class="section-title animate-on-scroll" data-i18n="media-video2-title">Plan para <span class="accent">Reanimar</span> una Economía</h2>
        <p class="section-sub animate-on-scroll" data-i18n="media-video2-desc">
          Nuestra visión estratégica para transformar el tejido empresarial dominicano a través de la formalización, tecnología e IA.
        </p>
        <div class="media-player animate-on-scroll">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/hrlKiOTJ_RI" title="RCP: Plan para Reanimar una Economía"
              frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- PODCAST -->
    <section class="section solucion">
      <div class="container">
        <div class="section-label animate-on-scroll" data-i18n="media-podcast-label">Podcast</div>
        <h2 class="section-title animate-on-scroll" data-i18n="media-podcast-title">Pretotipado y el <span class="accent">costo real</span> de crecer</h2>
        <p class="section-sub animate-on-scroll" data-i18n="media-podcast-desc">
          Una conversación profunda sobre estrategia empresarial, validación de ideas y cómo reducir riesgos antes de invertir en el crecimiento de tu negocio.
        </p>
        <div class="media-player audio-player animate-on-scroll">
          <div class="podcast-card">
            <div class="podcast-icon">🎙️</div>
            <div class="podcast-info">
              <h3 data-i18n="media-podcast-ep">Episodio 1</h3>
              <p data-i18n="media-podcast-name">Pretotipado y el costo real de crecer</p>
            </div>
          </div>
          <iframe style="border-radius:12px" src="https://open.spotify.com/embed/episode/02EtL8PAFf932ZlVZ00Z2t?utm_source=generator&theme=0"
            width="100%" height="152" frameBorder="0" allowfullscreen=""
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
        </div>
        <div class="media-player audio-player animate-on-scroll" style="margin-top:24px;">
          <div class="podcast-card">
            <div class="podcast-icon">🎙️</div>
            <div class="podcast-info">
              <h3 data-i18n="media-podcast-ep2">Episodio 2</h3>
              <p data-i18n="media-podcast-name2">Nuevo episodio disponible</p>
            </div>
          </div>
          <iframe style="border-radius:12px" src="https://open.spotify.com/embed/episode/6YuiTIdA2ZcACgZRxjP6jE?utm_source=generator&theme=0"
            width="100%" height="152" frameBorder="0" allowfullscreen=""
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
        </div>
        <div class="media-details animate-on-scroll">
          <h3 data-i18n="media-podcast-notes-title">📋 Temas del episodio</h3>
          <ul>
            <li data-i18n="media-podcast-note1">Técnicas de pretotipado para validar ideas antes de invertir</li>
            <li data-i18n="media-podcast-note2">Experimento "Puerta Falsa": Landing Page para medir el Nivel Inicial de Interés (NII)</li>
            <li data-i18n="media-podcast-note3">MVP "Mago de Oz": Ejecución hiperpersonalizada para validar el Product-Market Fit</li>
            <li data-i18n="media-podcast-note4">Cómo RCP Services aplica la validación estratégica en cada proyecto</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section paquetes" style="text-align:center;">
      <div class="container animate-on-scroll">
        <h2 class="section-title" data-i18n="media-cta-title">¿Listo para <span class="accent">dar el paso</span>?</h2>
        <p class="section-sub" data-i18n="media-cta-sub">Agenda tu diagnóstico 360° gratuito y comienza tu transformación.</p>
        <a href="/#contacto" class="btn-cta btn-lg" style="margin-top:24px;" data-i18n="media-cta-btn">Solicitar Diagnóstico Gratis →</a>
      </div>
    </section>
  </main>
</BaseLayout>
