<script>
  // Script interactivo autocontenido ejecutado client-side en Astro
  (function() {
    const inputInversion = document.getElementById('inputInversion') as HTMLInputElement;
    const inputVentas = document.getElementById('inputVentas') as HTMLInputElement;
    const inputRoyalty = document.getElementById('inputRoyalty') as HTMLInputElement;

    const displayInversion = document.getElementById('displayInversion')!;
    const displayVentas = document.getElementById('displayVentas')!;
    const displayRoyalty = document.getElementById('displayRoyalty')!;

    const valTotalRetorno = document.getElementById('valTotalRetorno')!;
    const valPagoMensual = document.getElementById('valPagoMensual')!;
    const valMeses = document.getElementById('valMeses')!;
    const progressFill = document.getElementById('simProgressFill')!;

    function formatDOP(value: number): string {
      return 'RD$ ' + value.toLocaleString('es-DO', { maximumFractionDigits: 0 });
    }

    function calculate() {
      const inversion = parseFloat(inputInversion.value);
      const ventas = parseFloat(inputVentas.value);
      const royaltyPct = parseFloat(inputRoyalty.value);

      // Actualizar displays de inputs
      displayInversion.textContent = formatDOP(inversion);
      displayVentas.textContent = formatDOP(ventas);
      displayRoyalty.textContent = royaltyPct + '%';

      // Cálculos
      const capRetorno = inversion * 1.5;
      const pagoMensual = ventas * (royaltyPct / 100);
      const meses = capRetorno / pagoMensual;

      // Actualizar outputs
      valTotalRetorno.textContent = formatDOP(capRetorno);
      valPagoMensual.textContent = formatDOP(pagoMensual);
      
      if (meses === Infinity || isNaN(meses)) {
        valMeses.textContent = 'N/A';
      } else {
        valMeses.textContent = meses.toFixed(1) + ' meses';
      }

      // Animación de barra de progreso basada en el tiempo de repago
      let progressPct = 0;
      if (meses <= 24) {
        progressPct = Math.max(10, Math.min(100, ((24 - meses) / 21) * 100));
      } else {
        progressPct = 10;
      }
      progressFill.style.width = progressPct + '%';
    }

    // Eventos
    if (inputInversion && inputVentas && inputRoyalty) {
      inputInversion.addEventListener('input', calculate);
      inputVentas.addEventListener('input', calculate);
      inputRoyalty.addEventListener('input', calculate);
      
      calculate();
    }
  })();
</script>
