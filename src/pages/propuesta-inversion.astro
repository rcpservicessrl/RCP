---
/**
 * propuesta-inversion.astro — Presentación Web Interactiva para Socio Consultor e Inversor.
 * Incluye tesis de negocio, tracción orgánica real, modelo híbrido (RCP Custom vs Odoo Plan B), presupuesto optimizado de RD$ 200k,
 * y un Simulador Interactivo de Retorno bajo el modelo de Revenue Share.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Propuesta de Inversión y Alianza Estratégica — RCP Services"
  description="Financiamiento no dilutivo y de mutuo beneficio para la expansión tecnológica y homologación fiscal de RCP Services SRL."
  canonical="/propuesta-inversion"
  active="propuesta-inversion"
>
  <main class="pitch-main">
    <!-- Hero Section -->
    <section class="pitch-hero">
      <div class="container hero-container">
        <span class="confidential-badge">💼 PROPUESTA DE ALIANZA & CAPITAL INTELIGENTE</span>
        <h1>Inversión y <span class="accent">Mentoría Estratégica</span></h1>
        <p class="subtitle">Una oportunidad de financiamiento no dilutivo para liderar la homologación fiscal ante la DGII y la expansión del software soberano de RCP Services SRL.</p>
        <div class="hero-actions">
          <a href="#traccion" class="btn-primary">Ver Tracción Real</a>
          <a href="#simulador" class="btn-secondary">Simular Retorno</a>
        </div>
      </div>
      <div class="hero-glow"></div>
    </section>

    <!-- La Propuesta de Valor para el Inversor/Consultor -->
    <section class="pitch-section section-dark">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">NUESTRO DIFERENCIADOR</span>
          <h2>El Poder de una Agencia 360°</h2>
          <p>Para capturar y retener clientes en el mercado dominicano de MIPYMEs, combinamos la tecnología de punta con una estructura de soporte corporativo completo:</p>
        </div>

        <div class="opportunity-grid">
          <div class="opp-card">
            <div class="opp-icon">🛡️</div>
            <h3>Cumplimiento DGII</h3>
            <p>La Ley 126-23 obliga a las empresas a migrar a la facturación electrónica. RCP actúa como el proveedor legal directo para cumplir con la DGII de forma ágil y transparente.</p>
          </div>
          <div class="opp-card highlighted">
            <div class="opp-icon">🐆</div>
            <h3>Equipo Multidisciplinario</h3>
            <p>Acaparamos todas las necesidades del cliente (marca, legal, fiscal, e-commerce e IA) bajo una misma firma, eliminando la fricción de coordinar múltiples proveedores independientes.</p>
          </div>
          <div class="opp-card">
            <div class="opp-icon">🤝</div>
            <h3>Socio Consultor (Smart Capital)</h3>
            <p>Buscamos un aliado que no solo aporte capital resiliente, sino que actúe como consultor estratégico para acelerar nuestra expansión comercial y consolidación corporativa.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TRACCIÓN Y VALIDACIÓN REAL -->
    <section id="traccion" class="pitch-section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">VALIDACIÓN DE MERCADO</span>
          <h2>Tracción Orgánica y Clientes Activos</h2>
          <p>La demanda de nuestra plataforma ha sido validada sin inversión en marketing ni campañas publicitarias. El interés orgánico en nuestras facilidades de pago y tecnología cerró los primeros contratos:</p>
        </div>

        <div class="traction-dashboard">
          <div class="traction-stats">
            <div class="stat-box">
              <span class="stat-num">9</span>
              <span class="stat-lbl">Proyectos Totales</span>
            </div>
            <div class="stat-box">
              <span class="stat-num">100%</span>
              <span class="stat-lbl">Setup Cobrado</span>
            </div>
            <div class="stat-box">
              <span class="stat-num">RD$ 0</span>
              <span class="stat-lbl">Gasto en Publicidad</span>
            </div>
          </div>

          <div class="projects-list-container">
            <h3>Portafolio de Clientes Iniciales</h3>
            <p class="section-desc">Negocios que ya pagaron la cuota de setup de RD$ 6,000 (tarifa de promoción para fundadores) y están activos en el plan de pago recurrente mensual:</p>
            
            <div class="projects-grid">
              <div class="project-item done">
                <span class="proj-badge">DESARROLLADO</span>
                <h4>Tienda de Embutidos La Solución</h4>
                <p>Soporte de inventario y facturación integrado.</p>
              </div>
              <div class="project-item done">
                <span class="proj-badge">DESARROLLADO</span>
                <h4>Liquor Store Fenómeno</h4>
                <p>Punto de venta y control de caja.</p>
              </div>
              <div class="project-item progress">
                <span class="proj-badge orange">EN DESARROLLO</span>
                <h4>Imprenta Norcentral</h4>
                <p>Gestión de órdenes y facturación.</p>
              </div>
              <div class="project-item progress">
                <span class="proj-badge orange">EN DESARROLLO</span>
                <h4>Telo'Corp Group</h4>
                <p>Estructura operativa e inventario.</p>
              </div>
            </div>

            <div class="pipeline-alert">
              <span>🚀 <strong>5 Proyectos Adicionales en Carpeta:</strong> En proceso de diseño y desarrollo, con cuota de setup saldada y listos para sumarse al abono recurrente mensual.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- El Ecosistema Híbrido (Plan A vs Plan B) -->
    <section class="pitch-section section-dark">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">ESTRATEGIA DE MERCADO</span>
          <h2>Nuestra Línea de Productos</h2>
          <p>Priorizamos el desarrollo propietario para retener el 100% de control comercial, ofreciendo soluciones de terceros como contingencia para optimizar la conversión:</p>
        </div>

        <div class="strategy-hybrid">
          <!-- Producto Propietario RCP Custom -->
          <div class="hybrid-card premium">
            <div class="card-glow-gold"></div>
            <div class="hybrid-badge gold">PLAN A: PRODUCTO ESTRELLA (RCP CUSTOM)</div>
            <h3>Sistemas a Medida RCP</h3>
            <p class="hybrid-desc">Desarrollo propio a la medida y sobre plantillas funcionales RCP. Nos permite control total del código y el 100% del margen de ganancia.</p>
            <ul class="hybrid-list">
              <li>🧠 <strong>Ecosistema Soberano:</strong> Ejecución local en servidores de GPU con asistentes de IA (Ollama) sin pagar APIs externas.</li>
              <li>⚡ <strong>Facturación Integrada:</strong> Enlace nativo con los flujos de la DGII diseñado desde cero para el cliente.</li>
              <li>🎨 <strong>Control de Marca:</strong> Integración fluida con los servicios de marketing y rebranding de nuestra agencia 360.</li>
            </ul>
            <div class="price-pill gold">Desde RD$ 25,000 setup / Abonos variables</div>
          </div>

          <!-- Odoo Cloud / Partner -->
          <div class="hybrid-card">
            <div class="card-glow-blue"></div>
            <div class="hybrid-badge">PLAN B: SOFTWARE DE TERCEROS (CONCESIONES)</div>
            <h3>Partner Oficial de Odoo</h3>
            <p class="hybrid-desc">Para clientes que exigen una plataforma prediseñada o certificada mundialmente en la nube.</p>
            <ul class="hybrid-list">
              <li>💼 <strong>Comisión de Licencias:</strong> Ganamos comisiones directas por venta de software oficial de Odoo.</li>
              <li>🔧 <strong>Integración e-CF:</strong> Actuamos como el enlace técnico para integrar la factura electrónica.</li>
              <li>🎓 <strong>Soporte e Igualas:</strong> Cobramos por asistencia técnica recurrente y capacitación de personal en los módulos.</li>
            </ul>
            <div class="price-pill">Desde RD$ 1,500/mes</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Presupuesto Optimizado (Plan CAPEX sin scroll) -->
    <section id="presupuesto" class="pitch-section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">PLAN DE CAPEX</span>
          <h2>Destino de los Fondos: <span class="accent">RD$ 200,000</span></h2>
          <p>Presupuesto estructurado para maximizar la eficiencia del capital, eliminando costos fijos inmobiliarios y enfocándose en activos de alto retorno legal y técnico:</p>
        </div>

        <div class="budget-layout">
          <div class="budget-table-container">
            <table class="budget-table">
              <thead>
                <tr>
                  <th>Concepto de Inversión</th>
                  <th>Monto (RD$)</th>
                  <th>Uso y Retorno Técnico</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td data-label="Concepto de Inversión"><strong>Constitución Legal (SRL)</strong></td>
                  <td data-label="Monto" class="table-amount">RD$ 50,000</td>
                  <td data-label="Uso y Retorno Técnico">ONAPI, Registro Mercantil, RNC y adecuación legal de socios.</td>
                </tr>
                <tr>
                  <td data-label="Concepto de Inversión"><strong>Actualización de GPU Local</strong></td>
                  <td data-label="Monto" class="table-amount">RD$ 80,000</td>
                  <td data-label="Uso y Retorno Técnico">Adquisición de GPU (RTX 4080 Super / 4090) para el servidor de desarrollo local e IA.</td>
                </tr>
                <tr>
                  <td data-label="Concepto de Inversión"><strong>Certificación DGII & Seguridad</strong></td>
                  <td data-label="Monto" class="table-amount">RD$ 40,000</td>
                  <td data-label="Uso y Retorno Técnico">Firma digital (Avansi), pruebas técnicas del módulo e-CF y cumplimiento regulatorio.</td>
                </tr>
                <tr>
                  <td data-label="Concepto de Inversión"><strong>Capital de Trabajo Inicial</strong></td>
                  <td data-label="Monto" class="table-amount">RD$ 30,000</td>
                  <td data-label="Uso y Retorno Técnico">Fondo de maniobra para el "Gig Hub" (freelancers) y marketing B2B.</td>
                </tr>
                <tr class="total-row">
                  <td data-label="Concepto de Inversión"><strong>Total Requerido</strong></td>
                  <td data-label="Monto" class="table-amount">RD$ 200,000</td>
                  <td data-label="Uso y Retorno Técnico"><strong>CAPEX 100% Optimizado y Sin Sobrecostos</strong></td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="budget-insight-card">
            <h3>Eficiencia de Oficina</h3>
            <p>Para las MIPYMEs y medianas empresas de R.D., la captación estratégica y el cierre comercial se realiza mediante <strong>visita y consultoría presencial directa</strong> en las oficinas corporativas del cliente. Esto mantiene el CAPEX inmobiliario en cero y eleva la tasa de conversión.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Simulador de Retorno de Revenue Share -->
    <section id="simulador" class="pitch-section section-dark">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">SIMULADOR FINANCIERO</span>
          <h2>Retorno Líquido e Interactivos</h2>
          <p>Para proteger el control de RCP Services y asegurar una alianza resiliente, te ofrecemos un modelo de **Revenue Share (Regalías)**. Ajustá los sliders para proyectar el flujo de repago:</p>
        </div>

        <div class="simulator-card">
          <div class="simulator-inputs">
            <!-- Input 1: Monto Inversion -->
            <div class="input-group">
              <div class="label-row">
                <label for="inputInversion">Monto de Inversión:</label>
                <span class="value-display" id="displayInversion">RD$ 200,000</span>
              </div>
              <input type="range" id="inputInversion" min="50000" max="200000" step="10000" value="200000" class="sim-slider" />
            </div>

            <!-- Input 2: Ventas Mensuales -->
            <div class="input-group">
              <div class="label-row">
                <label for="inputVentas">Facturación Mensual de RCP (Proyectada):</label>
                <span class="value-display" id="displayVentas">RD$ 400,000</span>
              </div>
              <input type="range" id="inputVentas" min="100000" max="1500000" step="50000" value="400000" class="sim-slider" />
            </div>

            <!-- Input 3: Porcentaje Regalía -->
            <div class="input-group">
              <div class="label-row">
                <label for="inputRoyalty">Porcentaje de Regalía (Revenue Share):</label>
                <span class="value-display" id="displayRoyalty">7%</span>
              </div>
              <input type="range" id="inputRoyalty" min="5" max="12" step="1" value="7" class="sim-slider" />
            </div>
          </div>

          <div class="simulator-outputs">
            <div class="output-glow"></div>
            <div class="output-inner">
              <h3>Veredicto del Retorno</h3>
              
              <div class="metric-grid">
                <div class="metric-item">
                  <span class="metric-lbl">Tope de Retorno (1.5x)</span>
                  <span class="metric-val accent" id="valTotalRetorno">RD$ 300,000</span>
                </div>
                <div class="metric-item">
                  <span class="metric-lbl">Pago Mensual al Inversor</span>
                  <span class="metric-val" id="valPagoMensual">RD$ 28,000</span>
                </div>
              </div>

              <!-- Progress bar animada -->
              <div class="progress-container">
                <div class="progress-lbl-row">
                  <span>Inversión Inicial</span>
                  <span>100% Repagado (1.5x)</span>
                </div>
                <div class="progress-track">
                  <div class="progress-fill" id="simProgressFill"></div>
                </div>
              </div>

              <div class="time-verdict">
                <p>Tiempo Estimado de Repago: <strong id="valMeses" class="accent-text">10.7 meses</strong></p>
                <span class="verdict-note">Una vez alcanzado el tope de retorno (1.5x), el acuerdo de regalías expira por completo. El inversor mantiene su rol de asesor consultor preferente.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Condiciones del Trato -->
    <section class="pitch-section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">EL ACUERDO</span>
          <h2>Condiciones de la Alianza</h2>
          <p>Estructuramos un trato de capital inteligente (smart money) diseñado para proteger la sociedad:</p>
        </div>

        <div class="rules-grid">
          <div class="rule-card">
            <h3>🔒 Cero Dilución Societaria</h3>
            <p>El fundador retiene el 100% de las acciones comunes y del voto político. El inversor no asume control de voto en las juntas ordinarias.</p>
          </div>
          <div class="rule-card">
            <h3>📈 Amortización Variable y Flexible</h3>
            <p>Los pagos mensuales de regalías se adaptan al volumen real de facturación del mes, mitigando riesgos de flujo de caja para la empresa.</p>
          </div>
          <div class="rule-card">
            <h3>💡 Rol de Consultoría Activa</h3>
            <p>El socio inversor tiene derecho preferencial de consultoría y mentoría de negocios para optimizar nuestra expansión comercial B2B.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Reset general para el pitch */
  .pitch-main {
    background: #060608;
    color: #e8e8ea;
    padding-top: 80px;
    font-family: var(--font);
    overflow-x: hidden;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Sección base */
  .pitch-section {
    padding: 100px 0;
  }

  .section-dark {
    background: #0c0c0e;
    border-top: 1px solid rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  }

  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 60px;
  }

  .section-tag {
    display: inline-block;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .section-header h2 {
    font-size: 2.2rem;
    font-weight: 900;
    margin-bottom: 16px;
  }

  .section-header p {
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .accent {
    color: var(--accent);
  }

  /* Hero Section */
  .pitch-hero {
    position: relative;
    padding: 120px 0 100px;
    text-align: center;
    background: radial-gradient(circle at center, #18140f 0%, #060608 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  }

  .hero-container {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .confidential-badge {
    display: inline-block;
    background: rgba(252, 181, 63, 0.1);
    border: 1px solid rgba(252, 181, 63, 0.25);
    color: var(--accent);
    padding: 6px 14px;
    border-radius: 30px;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: 1px;
  }

  .pitch-hero h1 {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .pitch-hero .subtitle {
    font-size: 1.15rem;
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 700;
    text-decoration: none;
    transition: var(--transition);
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(252, 181, 63, 0.24);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text);
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 700;
    text-decoration: none;
    transition: var(--transition);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 300px;
    background: rgba(252, 181, 63, 0.03);
    filter: blur(100px);
    pointer-events: none;
    z-index: 1;
  }

  /* Opportunity Grid */
  .opportunity-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 40px;
  }

  .opp-card {
    background: #111113;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 16px;
    padding: 32px;
    transition: var(--transition);
  }

  .opp-card:hover {
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-4px);
  }

  .opp-card.highlighted {
    border-color: rgba(252, 181, 63, 0.3);
    background: linear-gradient(145deg, #111113 0%, #1a1610 100%);
  }

  .opp-icon {
    font-size: 2.2rem;
    margin-bottom: 20px;
  }

  .opp-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .opp-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Tracción / Proyectos */
  .traction-dashboard {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .traction-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .stat-box {
    background: #111113;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
  }

  .stat-num {
    display: block;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .stat-lbl {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .projects-list-container {
    background: #0c0c0e;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 24px;
    padding: 40px;
  }

  .projects-list-container h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 30px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .project-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }

  .proj-badge {
    display: inline-block;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.2);
    font-size: 0.65rem;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 12px;
  }

  .proj-badge.orange {
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  .project-item h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .project-item p {
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .pipeline-alert {
    background: rgba(252, 181, 63, 0.05);
    border: 1px solid rgba(252, 181, 63, 0.15);
    border-radius: 12px;
    padding: 16px 24px;
    font-size: 0.9rem;
    color: var(--text);
  }

  /* Hybrid Strategy */
  .strategy-hybrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 32px;
  }

  .hybrid-card {
    position: relative;
    background: #0c0c0e;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 24px;
    padding: 48px;
    overflow: hidden;
  }

  .hybrid-card.premium {
    background: linear-gradient(145deg, #0c0c0e 0%, #1c160e 100%);
    border-color: rgba(252, 181, 63, 0.2);
  }

  .hybrid-badge {
    display: inline-block;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    color: #3b82f6;
    padding: 4px 12px;
    border-radius: 30px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 1px;
    margin-bottom: 24px;
  }

