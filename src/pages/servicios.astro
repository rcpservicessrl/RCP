---
/**
 * servicios.astro — Catálogo de paquetes 360° con filtro por etapa
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Business Consulting, Advertising, Digital Transformation",
  "provider": { "@type": "Organization", "name": "RCP Services", "url": "https://rcp.services" },
  "areaServed": "Dominican Republic",
  "description": "Servicios 360° para MIPYMEs: renovación empresarial, consultoría legal y financiera, publicidad digital y paquetes personalizados."
};
---

<BaseLayout
  title="Servicios 360° - RCP Services | Catálogo Interactivo para MIPYMEs"
  description="Catálogo de servicios 360° de RCP Services: renovación empresarial, consultoría legal y financiera, publicidad digital, y paquetes personalizados para MIPYMEs en República Dominicana."
  canonical="/servicios"
  active="servicios"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <main>
    <section class="hero hero-short" id="inicio">
      <div class="hero-bg-grid"></div>
      <div class="container" style="position: relative; width: 100%; padding-top: 120px;">
        <div class="hero-content">
          <div class="hero-badge animate-fade-up">
            <span class="badge-dot"></span> <span data-i18n="cat-badge">Catálogo Interactivo 360°</span>
          </div>
          <h1 class="hero-title animate-fade-up delay-1" data-i18n="cat-title">
            Diseña tu ruta de <span class="accent">transformación</span>
          </h1>
          <p class="hero-sub animate-fade-up delay-2" data-i18n="cat-sub">
            Elige uno de nuestros paquetes estratégicos optimizados o selecciona bloques individuales a la carta para crear una experiencia totalmente adaptada a tu negocio.
          </p>
        </div>
        <figure class="service-visual-language animate-fade-up delay-2" aria-hidden="true">
          <img src="/assets/brand/rcp-visual-language-services.png" alt="" width="1536" height="1024" loading="eager" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-label animate-on-scroll" data-i18n="cat-filter-label">Tu Situación Actual</div>
        <h2 class="section-title animate-on-scroll" data-i18n="cat-filter-title">¿En qué etapa se encuentra tu <span class="accent">negocio</span>?</h2>
        <p class="section-sub animate-on-scroll" data-i18n="cat-filter-sub">Selecciona tu etapa para ver la recomendación ideal de nuestro instinto leopardo.</p>

        <div class="catalog-filter animate-on-scroll">
          <button class="filter-pill active" data-stage="startup">
            <span class="pill-icon">🌱</span>
            <div class="pill-text">
              <span class="pill-title" data-i18n="cat-stage1-title">Idea / Informal</span>
              <span class="pill-desc" data-i18n="cat-stage1-desc">Quiero formalizarme y lanzar</span>
            </div>
          </button>
          <button class="filter-pill" data-stage="growth">
            <span class="pill-icon">📈</span>
            <div class="pill-text">
              <span class="pill-title" data-i18n="cat-stage2-title">Activo / Crecimiento</span>
              <span class="pill-desc" data-i18n="cat-stage2-desc">Busco organizar e impulsar ventas</span>
            </div>
          </button>
          <button class="filter-pill" data-stage="leader">
            <span class="pill-icon">🚀</span>
            <div class="pill-text">
              <span class="pill-title" data-i18n="cat-stage3-title">Escalar / Liderazgo</span>
              <span class="pill-desc" data-i18n="cat-stage3-desc">Automatizar al 100% con IA privada</span>
            </div>
          </button>
        </div>

        <div class="catalog-grid animate-on-scroll">
          <div class="package-detail-card" id="pkg-basico">
            <div class="pkg-header">
              <span class="pkg-tier" data-i18n="tier-basico">Básico</span>
              <h3 class="pkg-name" data-i18n="name-basico">Reanimación Temprana</h3>
              <p class="pkg-desc" data-i18n="cat-basico-short">Bases legales, fiscales y visuales sólidas para iniciar con fuerza.</p>
              <div class="pkg-price-box">
                <span class="pkg-price-range">RD$ 20,000 - 35,000</span>
                <span class="pkg-price-tag" data-i18n="label-basico">Pago único</span>
              </div>
              <span class="timeline-badge">⏱️ 1 - 3 <span data-i18n="weeks">Semanas</span></span>
            </div>
            <div class="pkg-body">
              <ul class="pkg-features">
                <li><span class="check">✓</span> <strong data-i18n="cat-feat-1">Diagnóstico 360° Inicial</strong></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-2">Formalización ONAPI (Nombre comercial)</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-3">Registro Mercantil (Cámara de Comercio)</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-4">RNC DGII (Registro Nacional del Contribuyente)</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-5">Logotipo e Identidad Visual Básica</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-6">Landing Page autoadministrable de Captura</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-7">Base de Datos de Clientes Básica</span></li>
              </ul>
              <a href="/checkout?package=basico" class="btn-cta btn-full" data-i18n="cat-buy-basico">Adquirir Paquete</a>
            </div>
          </div>

          <div class="package-detail-card featured" id="pkg-avanzado">
            <div class="featured-badge" data-i18n="badge-premium">⭐ RECOMENDADO</div>
            <div class="pkg-header">
              <span class="pkg-tier" data-i18n="tier-avanzado">Avanzado</span>
              <h3 class="pkg-name" data-i18n="name-avanzado">Estabilización y Crecimiento</h3>
              <p class="pkg-desc" data-i18n="cat-avanzado-short">Integración total del ERP/CRM centralizado y marketing digital activo.</p>
              <div class="pkg-price-box">
                <div class="pkg-price-split">
                  <div>
                    <span class="price-type" data-i18n="setup-label">Instalación:</span>
                    <span class="pkg-price-range font-sm">RD$ 40,000 - 60,000</span>
                  </div>
                  <div class="price-separator">/</div>
                  <div>
                    <span class="price-type" data-i18n="monthly-label">Iguala:</span>
                    <span class="pkg-price-range font-sm">RD$ 15,000 - 25,000</span>
                  </div>
                </div>
                <span class="pkg-price-tag" data-i18n="label-avanzado">Setup + Iguala mensual</span>
              </div>
              <span class="timeline-badge">⏱️ 3 - 4 <span data-i18n="weeks">Semanas</span></span>
            </div>
            <div class="pkg-body">
              <ul class="pkg-features">
                <li><span class="check text-gold">✓</span> <strong data-i18n="cat-feat-8">Todo lo del paquete Básico, MÁS:</strong></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-9">Auditoría Financiera y Planificación Fiscal</span></li>
                <li><span class="check">✓</span> <strong data-i18n="cat-feat-10">Instalación Ecosistema ERP + CRM Corporativo</strong></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-11">Control centralizado de Inventario, Compras y Ventas</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-12">Motor de Automatización de Leads</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-13">Campañas Activas de Publicidad (Meta/Google Ads)</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-14">Posicionamiento SEO Local Dominicana</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-15">Reporte mensual de rendimiento directivo</span></li>
              </ul>
              <a href="/checkout?package=avanzado" class="btn-cta btn-full" data-i18n="cat-buy-avanzado">Adquirir Paquete</a>
            </div>
          </div>

          <div class="package-detail-card" id="pkg-premium">
            <div class="pkg-header">
              <span class="pkg-tier" data-i18n="tier-premium">Premium</span>
              <h3 class="pkg-name" data-i18n="name-premium">Vitalidad y Liderazgo</h3>
              <p class="pkg-desc" data-i18n="cat-premium-short">Soberanía digital absoluta, IA Corporativa Privada y Dashboard Directivo.</p>
              <div class="pkg-price-box">
                <div class="pkg-price-split">
                  <div>
                    <span class="price-type" data-i18n="setup-label">Instalación:</span>
                    <span class="pkg-price-range font-sm">RD$ 75,000 - 120,000</span>
                  </div>
                  <div class="price-separator">/</div>
                  <div>
                    <span class="price-type" data-i18n="monthly-label">Retainer:</span>
                    <span class="pkg-price-range font-sm">RD$ 30,000 - 50,000</span>
                  </div>
                </div>
                <span class="pkg-price-tag" data-i18n="label-premium">Retainer mensual</span>
              </div>
              <span class="timeline-badge">⏱️ 4 - 6 <span data-i18n="weeks">Semanas</span></span>
            </div>
            <div class="pkg-body">
              <ul class="pkg-features">
                <li><span class="check text-gold">✓</span> <strong data-i18n="cat-feat-16">Todo lo del paquete Avanzado, MÁS:</strong></li>
                <li><span class="check">✓</span> <strong data-i18n="cat-feat-17">Motor de IA Corporativa Privada</strong></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-18">Chatbots corporativos entrenados con tus manuales</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-19">Estudio Creativo IA</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-20">Automatización avanzada de WhatsApp y CRM</span></li>
                <li><span class="check">✓</span> <strong data-i18n="cat-feat-21">Dashboard Directivo en tiempo real (LTV/CAC/ROAS)</strong></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-22">Acompañamiento en licitaciones (Ley 488-08)</span></li>
                <li><span class="check">✓</span> <span data-i18n="cat-feat-23">Asesoría de Junta Directiva Externa 24/7</span></li>
              </ul>
              <a href="/checkout?package=premium" class="btn-cta btn-full" data-i18n="cat-buy-premium">Adquirir Paquete</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background-color: var(--black-3);">
      <div class="container">
        <h2 class="section-title animate-on-scroll">¿Por qué confiar en <span class="accent">RCP Services</span>?</h2>
        <div class="cards-grid three-col animate-on-scroll" style="margin-top:40px;">
          <div class="trust-card">
            <div class="trust-icon">⚡</div>
            <h3>Rapidez</h3>
            <p>Implementaciones en semanas, no en meses. Metodologías ágiles de alta velocidad.</p>
          </div>
          <div class="trust-card">
            <div class="trust-icon">🏅</div>
            <h3>Calidad</h3>
            <p>Equipo multidisciplinario experto que audita cada entregable.</p>
          </div>
          <div class="trust-card">
            <div class="trust-icon">💎</div>
            <h3>Precio Justo</h3>
            <p>Costos transparentes adaptados a la realidad financiera de las MIPYMEs.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
